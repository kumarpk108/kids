            <Clues>
              <ClueItem Clue="Wife of King Janak; Mother of Sita" Number="1" />
              <ClueItem Clue="Lankan physician, who advised Sanjivani herbs from Kailas mountain in order to cure Laxman" Number="2" />
              <ClueItem Clue="Lord Rams birthday" Number="3" />
              <ClueItem Clue="Wise and learned monkey devotee of Sri Rama" Number="4" />
              <ClueItem Clue="Magical herb mentioned in the Ramayana" Number="5" />
              <ClueItem Clue="Ravan’s sister whose ears and nose were cut by Laxman" Number="6" />
              <ClueItem Clue="The place beside the river Godavari where Rama, Sita and Laxmana stayed in exile." Number="7" />
              <ClueItem Clue="The Seventh Avatara of Vishnu. Son of Dasarath" Number="8" />
              <ClueItem Clue="Brother of mighty Vali" Number="9" />
              <ClueItem Clue="Sitas father Janakas Kingdom" Number="10" />
              <ClueItem Clue="A place where Rama, Sita and Lakshmana spent their exile; The hermitages of Valmiki" Number="11" />
              <ClueItem Clue="Demoness or rakshasi killed by Rama; mother of Mareecha" Number="12" />
              <ClueItem Clue="One of Dasharathas four sons, King of Madhu." Number="13" />
              <ClueItem Clue="Uncle of Ravana who transformed himself into a golden deer" Number="14" />
              <ClueItem Clue="King of Ayodhya and Lord Ramas father." Number="15" />
            </Clues>
