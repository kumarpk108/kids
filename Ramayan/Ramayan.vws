              <ClueItem Clue="Sitas father Janakas Kingdom" Number="2" />
              <ClueItem Clue="Son of Vali" Number="3" />
              <ClueItem Clue="Its capital was Ayodhya, where Rama was born." Number="4" />
              <ClueItem Clue="King of Lanka who abducted Sita" Number="5" />
              <ClueItem Clue="Home of Ravana." Number="6" />
              <ClueItem Clue="King of Ayodhya and Lord Ramas father." Number="7" />
              <ClueItem Clue="One of Dasharathas four sons, King of Madhu." Number="8" />
              <ClueItem Clue="Brother of Ravana, who was asleep most of the time because of the curse of Brahma." Number="9" />
              <ClueItem Clue="Uncle of Ravana who transformed himself into a golden deer" Number="10" />
            </Clues>
