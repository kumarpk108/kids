          <ValueSets>
            <ValueSet>
              <Property Name="Clue" Type="String" Value="Maternal uncle of Ravana, slain by Hanumaan at seize." />
              <Property Name="Choices" Type="String" Value="A. TULSIDAS   B. MANDODARI   C. AKAMPANA   D. JATAYU" />
              <Property Name="Answer" Type="String" Value="C" />
            </ValueSet>
            <ValueSet>
              <Property Name="Clue" Type="String" Value="Magical herb mentioned in the Ramayana" />
              <Property Name="Choices" Type="String" Value="A. LAKSHMANA   B. SHABARI   C. SANJIVANI   D. MARICHA" />
              <Property Name="Answer" Type="String" Value="C" />
            </ValueSet>
            <ValueSet>
              <Property Name="Clue" Type="String" Value="Wife of sage Gautama, who was turned into a stone and later became free from curse by the touch of Rama" />
              <Property Name="Choices" Type="String" Value="A. HANUMAN   B. DASHARATHA   C. RAMANAVAMI   D. AHALYA" />
              <Property Name="Answer" Type="String" Value="D" />
            </ValueSet>
            <ValueSet>
              <Property Name="Clue" Type="String" Value="Eldest of King Dasharathas three wives and a queen of Ayodhya. She was the mother of Rama." />
              <Property Name="Choices" Type="String" Value="A. HANUMAN   B. KOSALA   C. KAUSALYA   D. SAMPATI" />
              <Property Name="Answer" Type="String" Value="C" />
            </ValueSet>
            <ValueSet>
              <Property Name="Clue" Type="String" Value="Kingdom ruled by a Vanara King Sugreeva" />
              <Property Name="Choices" Type="String" Value="A. KISHKINDHA   B. SHATRUGHNA   C. INDRAJIT   D. SHRUTKIRTI" />
              <Property Name="Answer" Type="String" Value="A" />
            </ValueSet>
            <ValueSet>
              <Property Name="Clue" Type="String" Value="Home of Ravana." />
              <Property Name="Choices" Type="String" Value="A. SITA   B. URMILA   C. LANKA   D. SANJIVANI" />
              <Property Name="Answer" Type="String" Value="C" />
            </ValueSet>
            <ValueSet>
              <Property Name="Clue" Type="String" Value="The place beside the river Godavari where Rama, Sita and Laxmana stayed in exile." />
              <Property Name="Choices" Type="String" Value="A. PANCHVATI   B. KUMBHAKARNA   C. BALI   D. TULSIDAS" />
              <Property Name="Answer" Type="String" Value="A" />
            </ValueSet>
            <ValueSet>
              <Property Name="Clue" Type="String" Value="Sons of Rama and Sita." />
              <Property Name="Choices" Type="String" Value="A. JANAKA   B. URMILA   C. VALMIKI   D. LAVA" />
              <Property Name="Answer" Type="String" Value="D" />
            </ValueSet>
            <ValueSet>
              <Property Name="Clue" Type="String" Value="King of Lanka who abducted Sita" />
              <Property Name="Choices" Type="String" Value="A. RAVANA   B. GUHAN   C. AYODHYA   D. JATAYU" />
              <Property Name="Answer" Type="String" Value="A" />
            </ValueSet>
            <ValueSet>
              <Property Name="Clue" Type="String" Value="Its capital was Ayodhya, where Rama was born." />
              <Property Name="Choices" Type="String" Value="A. GUHAN   B. KOSALA   C. RAMAYANA   D. KISHKINDHA" />
              <Property Name="Answer" Type="String" Value="B" />
            </ValueSet>
            <ValueSet>
              <Property Name="Clue" Type="String" Value="Ravan’s sister whose ears and nose were cut by Laxman" />
              <Property Name="Choices" Type="String" Value="A. RAMA   B. SHURPANAKHA   C. MADHU   D. VIBHISHANA" />
              <Property Name="Answer" Type="String" Value="B" />
            </ValueSet>
            <ValueSet>
              <Property Name="Clue" Type="String" Value="Boatman who let Rama, Laxman and Sita cross the river in his boat and washes Rama’s feet" />
              <Property Name="Choices" Type="String" Value="A. AHALYA   B. GUHAN   C. KAIKEYI   D. PANCHVATI" />
              <Property Name="Answer" Type="String" Value="B" />
            </ValueSet>
            <ValueSet>
              <Property Name="Clue" Type="String" Value="Sage/Rishi who cursed her wife Ahalya and turned her into a stone for her immoral conduct" />
              <Property Name="Choices" Type="String" Value="A. KOSALA   B. GAUTAMA   C. KUMBHAKARNA   D. TULSIDAS" />
              <Property Name="Answer" Type="String" Value="B" />
            </ValueSet>
            <ValueSet>
              <Property Name="Clue" Type="String" Value="Wife of Rama" />
              <Property Name="Choices" Type="String" Value="A. JATAYU   B. LAKSHMANA   C. TULSIDAS   D. SITA" />
              <Property Name="Answer" Type="String" Value="D" />
            </ValueSet>
            <ValueSet>
              <Property Name="Clue" Type="String" Value="First wife of the Ravana." />
              <Property Name="Choices" Type="String" Value="A. MANDODARI   B. RAVANA   C. VALMIKI   D. SITA" />
              <Property Name="Answer" Type="String" Value="A" />
            </ValueSet>
          </ValueSets>
