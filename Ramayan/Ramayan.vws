          <ClueItems1>
            <ClueItem>
              <Property Name="Clue" Type="String" Value="ACROSS" />
              <Property Name="ClueNumber" Type="String" Value="" />
            </ClueItem>
            <ClueItem>
              <Property Name="Clue" Type="String" Value="Its capital was Ayodhya, where Rama was born." />
              <Property Name="ClueNumber" Type="String" Value="1" />
            </ClueItem>
            <ClueItem>
              <Property Name="Clue" Type="String" Value="The name of Kingdom of Shatrughna." />
              <Property Name="ClueNumber" Type="String" Value="6" />
            </ClueItem>
            <ClueItem>
              <Property Name="Clue" Type="String" Value="The place beside the river Godavari where Rama, Sita and Laxmana stayed in exile." />
              <Property Name="ClueNumber" Type="String" Value="7" />
            </ClueItem>
            <ClueItem>
              <Property Name="Clue" Type="String" Value="Lord Rams birthday" />
              <Property Name="ClueNumber" Type="String" Value="10" />
            </ClueItem>
            <ClueItem>
              <Property Name="Clue" Type="String" Value="Devotee of Rama who offered him berries" />
              <Property Name="ClueNumber" Type="String" Value="12" />
            </ClueItem>
            <ClueItem>
              <Property Name="Clue" Type="String" Value="Wife of King Janak; Mother of Sita" />
              <Property Name="ClueNumber" Type="String" Value="13" />
            </ClueItem>
            <ClueItem>
              <Property Name="Clue" Type="String" Value="King of Ayodhya and Lord Ramas father." />
              <Property Name="ClueNumber" Type="String" Value="14" />
            </ClueItem>
            <ClueItem>
              <Property Name="Clue" Type="String" Value="Daughter of Kushadhwaja;  married to Shatrughna." />
              <Property Name="ClueNumber" Type="String" Value="15" />
            </ClueItem>
          </ClueItems1>
          <ClueItems2>
            <ClueItem>
              <Property Name="Clue" Type="String" Value="DOWN" />
              <Property Name="ClueNumber" Type="String" Value="" />
            </ClueItem>
            <ClueItem>
              <Property Name="Clue" Type="String" Value="Brother of mighty Vali" />
              <Property Name="ClueNumber" Type="String" Value="2" />
            </ClueItem>
            <ClueItem>
              <Property Name="Clue" Type="String" Value="Brother of Ravana, who was asleep most of the time because of the curse of Brahma." />
              <Property Name="ClueNumber" Type="String" Value="3" />
            </ClueItem>
            <ClueItem>
              <Property Name="Clue" Type="String" Value="A place where Rama, Sita and Lakshmana spent their exile; The hermitages of Valmiki" />
              <Property Name="ClueNumber" Type="String" Value="4" />
            </ClueItem>
            <ClueItem>
              <Property Name="Clue" Type="String" Value="Magical herb mentioned in the Ramayana" />
              <Property Name="ClueNumber" Type="String" Value="5" />
            </ClueItem>
            <ClueItem>
              <Property Name="Clue" Type="String" Value="Demoness or rakshasi killed by Rama; mother of Mareecha" />
              <Property Name="ClueNumber" Type="String" Value="8" />
            </ClueItem>
            <ClueItem>
              <Property Name="Clue" Type="String" Value="King of Mithila, a great Rajarishi; father of Sita" />
              <Property Name="ClueNumber" Type="String" Value="9" />
            </ClueItem>
            <ClueItem>
              <Property Name="Clue" Type="String" Value="Wife of sage Gautama, who was turned into a stone and later became free from curse by the touch of Rama" />
              <Property Name="ClueNumber" Type="String" Value="11" />
            </ClueItem>
          </ClueItems2>
