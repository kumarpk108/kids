              <ClueItem Clue="King of Ayodhya and Lord Ramas father." Number="33" />
              <ClueItem Clue="Brother of Ravana, who was asleep most of the time because of the curse of Brahma." Number="34" />
              <ClueItem Clue="The Seventh Avatara of Vishnu. Son of Dasarath" Number="35" />
              <ClueItem Clue="The name of Kingdom of Shatrughna." Number="36" />
              <ClueItem Clue="Wife of sage Gautama, who was turned into a stone and later became free from curse by the touch of Rama" Number="37" />
              <ClueItem Clue="Daughter of Kushadhwaja;  married to Shatrughna." Number="38" />
              <ClueItem Clue="The place beside the river Godavari where Rama, Sita and Laxmana stayed in exile." Number="39" />
              <ClueItem Clue="Devotee of Rama who offered him berries" Number="40" />
              <ClueItem Clue="Brother of mighty Vali" Number="41" />
              <ClueItem Clue="Wise and learned monkey devotee of Sri Rama" Number="42" />
              <ClueItem Clue="Home of Ravana." Number="43" />
              <ClueItem Clue="Sitas father Janakas Kingdom" Number="44" />
              <ClueItem Clue="Uncle of Ravana who transformed himself into a golden deer" Number="45" />
              <ClueItem Clue="King of Lanka who abducted Sita" Number="46" />
